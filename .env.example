# MCP server
FASTMCP_HOST=0.0.0.0
FASTMCP_PORT=8000

# MCP namespace (default prefixes tools: qdrant-find, qdrant-store, ...)
NAMESPACE=qdrant

# Optional bearer token for HTTP transport (required in Authorization header)
# AUTH_BEARER_TOKEN=

# Qdrant connection (use http://qdrant:6333 when running with --profile with-qdrant)
QDRANT_URL=http://host.docker.internal:6333
QDRANT_API_KEY=
COLLECTION_NAME=default-collection
QDRANT_SEARCH_LIMIT=10
# QDRANT_READ_ONLY=false

# Embeddings: fastembed (local) or openai (OpenAI-compatible API)
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Required when EMBEDDING_PROVIDER=openai
# EMBEDDING_BASE_URL=https://your-embeddings-api.example.com
# EMBEDDING_API_KEY=
# EMBEDDING_EXPECTED_RESPONSE_MODEL=
# EMBEDDING_VECTOR_NAME=

# Optional Qdrant port when using the bundled Qdrant service
# QDRANT_PORT=6333
